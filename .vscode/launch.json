{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Indexer",
            "type": "python",
            "request": "launch",
            "interpreterPath": "${workspaceFolder}/indexer/.venv/bin/python",
            "program": "${workspaceFolder}/indexer/start.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/indexer",
            "justMyCode": true
        },
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}