{
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.env.linux": {
        "PYTHONPATH": "${workspaceFolder}/indexer/src"
    },
    "terminal.integrated.cwd": "${workspaceFolder}",
    "python.envFile": "${workspaceFolder}/indexer/.env",
    "python.analysis.extraPaths": [
        "${workspaceFolder}/indexer/src"
    ],
    "python.analysis.diagnosticSeverityOverrides": {
        "reportMissingTypeStubs": "none"
    },
    "editor.formatOnSave": true,
    "python.formatting.provider": "black",
    "editor.defaultFormatter": "ms-python.black-formatter",
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true
    },
    "python.formatting.blackArgs": [
        "--line-length=127"
    ],
    "python.formatting.blackPath": "${workspaceFolder}/indexer/.venv/bin/black",
    "flake8.args": [
        "--max-line-length=127",
        "--exclude=.tox,build",
        "--extend-ignore=E203,W503,E402,E501"
    ],
    "flake8.path": [
        "${workspaceFolder}/indexer/.venv/bin/flake8"
    ],
    "json.schemas": [],
    "json.validate.enable": false,
    "files.associations": {
        "extensions.json": "jsonc"
    },
    "cSpell.language": "en",
    "cSpell.enabled": true,
    "cSpell.showStatus": true,
    "cSpell.words": [
        "arweave",
        "aylsk",
        "bech",
        "Bech",
        "boto",
        "cblock",
        "checkmultisig",
        "CHECKMULTISIG",
        "colorlog",
        "colour",
        "dhash",
        "DOMAINNAME",
        "dotenv",
        "EQUALVERIFY",
        "fysfe",
        "getblockcount",
        "getblockhash",
        "getcblock",
        "getrawtransaction",
        "hashstring",
        "Keccak",
        "levelname",
        "lruga",
        "namedtuples",
        "prevalidated",
        "prevout",
        "pubkey",
        "pubkeys",
        "QUICKNODE",
        "regtest",
        "REGTEST",
        "reparse",
        "Reparse",
        "reparsed",
        "reparsing",
        "reqs",
        "shash",
        "stampchain",
        "subasset",
        "transactinos",
        "tvzm",
        "undolog",
        "unpackb",
        "unrecognised",
        "vout",
        "vouts",
        "witver"
    ],
    "makefile.configureOnOpen": false,
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": [
        "indexer/tests"
    ],
    "python.defaultInterpreterPath": "${workspaceFolder}/indexer/.venv/bin/python",
    "python.pythonPath": "${workspaceFolder}/indexer/.venv/bin/python",
    "python.venvPath": "${workspaceFolder}/indexer",
    
    // Add isort configuration
    "isort.args": [
        "--profile=black",
        "--line-length=127"
    ],
    "isort.path": ["${workspaceFolder}/indexer/.venv/bin/isort"],
    
    // Add mypy configuration via Pylance
    "python.analysis.typeCheckingMode": "strict",
    "python.analysis.autoImportCompletions": true,
    "python.linting.mypyEnabled": true,
    "python.linting.mypyPath": "${workspaceFolder}/indexer/.venv/bin/mypy",
    "python.linting.mypyArgs": [
        "--explicit-package-bases",
        "--config-file=${workspaceFolder}/indexer/pyproject.toml"
    ],
    
    // Add bandit (security linting)
    "python.linting.banditEnabled": true,
    "python.linting.banditPath": "${workspaceFolder}/indexer/.venv/bin/bandit",
    "python.linting.banditArgs": [
        "-r",
        "src/",
        "tests/", 
        "tools/",
        "-s",
        "B608",
        "-lll"
    ],
    
    // Ensure all linting is enabled
    "python.linting.enabled": true,
    
    // Format imports on save
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit"
    }
}