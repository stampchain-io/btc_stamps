# Environment Variables for btc_stamps

# Database Configuration (MySQL/MariaDB)
RDS_HOSTNAME=localhost
RDS_PORT=3306
RDS_DATABASE=btc_stamps
RDS_USER=admin
RDS_PASSWORD=
MYSQL_USER=admin
MYSQL_PASSWORD=

# Backend Configuration
BACKEND_POLL_INTERVAL=0.5

# Testing
MOCK_DB=0
USE_TEST_DB=0
TESTING=0

# Snapshot Path
SNAPSHOT_PATH=snapshots/reference_hashes.json

# AI API Keys (for TaskMaster)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
MISTRAL_API_KEY=
GOOGLE_API_KEY=

# AWS (if using S3 for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# Bitcoin/Counterparty Node
BITCOIN_RPC_URL=
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=
COUNTERPARTY_RPC_URL=
COUNTERPARTY_RPC_USER=
COUNTERPARTY_RPC_PASSWORD=

# Application Settings
LOG_LEVEL=INFO
DEBUG=false
